# Optional LLM provider configuration.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# Core local ports.
NETWORK_SERVER_PORT=4190
CHAT_VIEW_PORT=4181
OPS_VIEW_PORT=4182
WORKSHOP_VIEW_PORT=4184
POLIS_VIEW_PORT=4285
AGENT_VIEW_PORT=4187

# Optional local network sharing.
POLIS_PUBLIC_HOST=
POLIS_BIND_HOST=127.0.0.1
POLIS_LAUNCH_PUBLIC_HOST=
POLIS_LAUNCH_BIND_HOST=127.0.0.1
